# ── 1. Required ───────────────────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=0x...

# ── 2. Strategy ─────────────────────────────────────────────────────────────
ASSETS=btc,eth
DURATIONS=5m,15m
# Gamma: etkinlik listesi için tag (varsayılan 102127)
# GAMMA_TAG_ID=102127

MIN_EDGE=0.11                 # min teknik olasılık − piyasa fiyatı farkı (ör. 0.11 = %11)
MIN_CONFIDENCE=0.75           # min güven (0.5–1.0)
MIN_ORDER_USDC=7              # min emir boyutu (USDC)

# ── 3. Per-asset overrides (KEY_ASSET) ───────────────────────────────────────
# Global değerlerin üzerine yazar: MIN_EDGE_BTC, RSI_PERIOD_ETH, vb.
# MIN_EDGE_BTC=0.13
# MIN_CONFIDENCE_ETH=0.78
# CANDLE_LOOKBACK_BTC=200

# ── 4. Technical analysis ───────────────────────────────────────────────────
SPOT_EXCHANGE=binance
CANDLE_INTERVAL=1m
CANDLE_LOOKBACK=150
RSI_PERIOD=16
MACD_FAST=12
MACD_SLOW=28
MACD_SIGNAL=9
# Spot hacim: oran tanımlıysa altında sinyal yok
# VOLUME_MIN_RATIO=0.7
# VOLUME_AVG_BARS=20
# VOLUME_USE_CLOSED_CANDLE_ONLY=true

# ── 5. Cluster / edge / sizing ────────────────────────────────────────────────
# MIN_MARKET_YES_PRICE=0.15
# MAX_MARKET_YES_PRICE=0.92
# MIN_SECS_TO_CLOSE=45
# EXPIRY_DAMPEN_LAST_SECS=120
# CHEAP_TOKEN_PRICE_THRESHOLD=0.15
# CHEAP_TOKEN_MAX_USDC=5
# LARGE_ORDER_USDC_HARD_CAP=25
# CLUSTER_RSI_OVERSOLD=40
# CLUSTER_RSI_OVERBOUGHT=60
# CLUSTER_MOM5_ABS=0.003
# CLUSTER_MOM15_ABS=0.005

# ── 6. Volatility filter ──────────────────────────────────────────────────────
# Son VOL_SAMPLE_BARS getirinin örneklem std’si ×100 (yüzde değil). Tanımsız min/max = kapalı.
# VOL_MIN_STD_PCT=0.0
# VOL_MAX_STD_PCT=
# VOL_SAMPLE_BARS=20
# VOL_MIN_STD_PCT_BTC=
# VOL_MAX_STD_PCT_BTC=

# ── 7. Risk ─────────────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.03         # işlem başına bakiye üst sınırı (ör. 0.03 = %3)
DAILY_LOSS_LIMIT_PCT=0.07
INITIAL_BALANCE=200

# ── 8. Higher timeframe filter ──────────────────────────────────────────────
# HTF_ENABLED=false
# HTF_INTERVAL=15m
# HTF_LOOKBACK=50
# HTF_EMA_PERIOD=20
# HTF_ENABLED_BTC=true

# ── 9. Adaptive thresholds ──────────────────────────────────────────────────
# ADAPTIVE_THRESHOLDS=false
# ADAPTIVE_TRADE_WINDOW=50

# ── 10. Execution ───────────────────────────────────────────────────────────
DRY_RUN=true
CYCLE_SECS=60
# CLOB_HOST=https://clob.polymarket.com
# SIGNATURE_TYPE=EOA
# FUNDER_ADDRESS=0x...

# Builder API (opsiyonel, market maker)
# BUILDER_API_KEY=
# BUILDER_API_SECRET=
# BUILDER_API_PASSPHRASE=

# ── 11. Metrics & data ───────────────────────────────────────────────────────
# DATA_DIR=data
# cargo run --bin stats -- --data-dir data

# ── 12. Observability ───────────────────────────────────────────────────────
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=polymarket-llm-bot
# LOG_JSON=false
# METRICS_ENABLED=true
# METRICS_BIND=127.0.0.1:9090
