# ── Secrets (gitignored `.env` only) ─────────────────────────────────────────
# Never put these in `config.toml` — keep them here or in your shell environment.
POLYMARKET_PRIVATE_KEY=0x...

# Required for Proxy / Gnosis Safe when applicable (see README).
# FUNDER_ADDRESS=0x...

# Optional Builder API (market maker features).
# BUILDER_API_KEY=
# BUILDER_API_SECRET=
# BUILDER_API_PASSPHRASE=

# Optional: load config from a non-default path.
# CONFIG_PATH=config.toml

# ── Strategy / TA / risk ─────────────────────────────────────────────────────
# Tunable parameters live in **`config.toml`** (version-controlled).
# Environment variables still override `config.toml` for quick experiments:
#   export MIN_EDGE=0.11
#   cargo run --release
#
# See `config.toml` in the repo root for the full schema and `[asset.btc]` / `[asset.eth]` overrides.
#
# Examples of overrides (same names as TOML / per-asset suffixes):
# SLIPPAGE_BPS=0.002
# MAX_SECS_TO_CLOSE=600
# MAX_SECS_TO_CLOSE_BTC=600
# CLUSTER_TIE_MIN_EDGE_MULTIPLIER=1.3
# MIN_MOMENTUM_5M_ABS=0.0008
# NEUTRAL_TAKER_EDGE_MULTIPLIER=1.5
# BLOCKED_DIRECTION_XRP=YES
