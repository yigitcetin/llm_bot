# ── Required ──────────────────────────────────────────────────────────────────
POLYMARKET_PRIVATE_KEY=0x...

# ── Strategy (optional — these are the defaults) ───────────────────────────────
ASSETS=btc,eth
DURATIONS=5m
# Gamma: list events by Polymarket tag (default 102127 = up/down style markets)
# GAMMA_TAG_ID=102127
MIN_EDGE=0.11            # minimum 6% edge to trade
MIN_CONFIDENCE=0.75      # minimum 70% technical signal confidence
MIN_ORDER_USDC=7         # minimum $5 per order

# Per-asset overrides (optional): `GLOBAL_KEY` + `_` + `ASSET` (uppercase), e.g. MIN_EDGE_BTC,
# RSI_PERIOD_ETH. `ASSETS` içindeki her varlık için ayrı ayrı tanımlanabilir; yoksa yukarıdaki
# global değer kullanılır. Canlı döngüde günlük zarar sayacı yalnızca global DAILY_LOSS_LIMIT_PCT
# ile kesilir; varlık sonekli DAILY_LOSS_LIMIT_PCT_* `analyze` ve ilerideki kullanım için okunur.
# MIN_EDGE_BTC=0.13
# MIN_EDGE_ETH=0.12
# MIN_CONFIDENCE_BTC=0.79
# MIN_CONFIDENCE_ETH=0.78
# CANDLE_LOOKBACK_BTC=200
# CANDLE_LOOKBACK_ETH=180
# RSI_PERIOD_BTC=20
# RSI_PERIOD_ETH=18
# SPOT_EXCHANGE_BTC=binance
# SPOT_EXCHANGE_ETH=binance

# Volatilite rejim filtresi (opsiyonel): son VOL_SAMPLE_BARS getirinin örneklem std’si ×100 (fiyat %’si değil).
# 0.05 çoğu 5m penceresinde aşırı sıkıdır → işlem kalmaz; 5m BTC için genelde 0.15–0.45 bandı denenir.
# min/max yoksa filtre kapalı. Örn. aşırı vol'da işlem yok: VOL_MAX_STD_PCT_BTC=0.35
# VOL_MIN_STD_PCT=0.0
# VOL_MAX_STD_PCT=
# VOL_SAMPLE_BARS=20
# VOL_MIN_STD_PCT_BTC=
# VOL_MAX_STD_PCT_BTC=
# VOL_SAMPLE_BARS_BTC=20

# ── Technical Analysis ────────────────────────────────────────────────────────
SPOT_EXCHANGE=binance    # spot price data source
CANDLE_INTERVAL=1m       # candle interval for technical analysis
CANDLE_LOOKBACK=150      # number of candles to fetch
RSI_PERIOD=16            # RSI calculation period
MACD_FAST=12             # MACD fast EMA period
MACD_SLOW=28             # MACD slow EMA period
MACD_SIGNAL=9            # MACD signal line period
# Spot hacim kalitesi (opsiyonel): son mum hacmi / son VOLUME_AVG_BARS ortalaması.
# Tanımlıysa oran altında sinyal üretilmez (analyze backtest: volume_low_skips).
# VOLUME_MIN_RATIO=0.7
# VOLUME_AVG_BARS=20

# ── Risk ───────────────────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.03    # max 5% of balance per trade
DAILY_LOSS_LIMIT_PCT=0.07
INITIAL_BALANCE=200      # starting balance for risk calculations

# ── Conservative profile (reference — tek dondurulmuş başlangıç; canlı öncesi doğrulayın) ─
# Multi-ufuk `analyze` çıktısına göre önerilen muhafazakâr taban. Her `analyze` turunda
# tablonun +edge/+conf önerilerini otomatik uygulamayın. BTC analizi için `MIN_EDGE_BTC` vb.
# kullanın; ETH için `MIN_EDGE_ETH` — veya aynı tabanı global `MIN_EDGE` ile verin.
#
# Örnek (varlık bazlı, önerilen):
# MIN_EDGE_BTC=0.13
# MIN_CONFIDENCE_BTC=0.79
# CANDLE_INTERVAL_BTC=1m
# CANDLE_LOOKBACK_BTC=200
# RSI_PERIOD_BTC=20
# MACD_FAST_BTC=12
# MACD_SLOW_BTC=30
# MACD_SIGNAL_BTC=9
# MAX_POSITION_PCT_BTC=0.03
# MIN_ORDER_USDC_BTC=7
#
# MIN_EDGE_ETH=0.12
# MIN_CONFIDENCE_ETH=0.78
# CANDLE_INTERVAL_ETH=1m
# CANDLE_LOOKBACK_ETH=200
# RSI_PERIOD_ETH=20
# MACD_FAST_ETH=12
# MACD_SLOW_ETH=30
# MACD_SIGNAL_ETH=9
# MAX_POSITION_PCT_ETH=0.03
# MIN_ORDER_USDC_ETH=7
#
# GLOBAL_BALANCE / günlük limit (cüzdan tek):
# DAILY_LOSS_LIMIT_PCT=0.07
# INITIAL_BALANCE=200
#
# İsteğe bağlı ek sıkılık: MAX_POSITION_PCT_*=0.025 veya global DAILY_LOSS_LIMIT_PCT=0.06
# Uzun vadede daha az gürültü için ayrı test: CANDLE_INTERVAL_*=5m

# ── 1m dondurulmuş profil (analyze sonrası — bir süre sabit tutun; her tur +edge yapmayın) ─
# BTC: 30g WF tutarlılığı sınırlı; ETH: 30g riski daha yüksek → ETH’de daha sıkı min order.
# Aşağıyı .env’e kopyalayıp (#) kaldırın veya mevcut *_BTC / *_ETH satırlarını güncelleyin.
#
# MIN_EDGE_BTC=0.14
# MIN_CONFIDENCE_BTC=0.80
# MIN_ORDER_USDC_BTC=7
# CANDLE_INTERVAL_BTC=1m
# CANDLE_LOOKBACK_BTC=200
# RSI_PERIOD_BTC=20
# MACD_FAST_BTC=12
# MACD_SLOW_BTC=30
# MACD_SIGNAL_BTC=9
# MAX_POSITION_PCT_BTC=0.03
#
# MIN_EDGE_ETH=0.15
# MIN_CONFIDENCE_ETH=0.82
# MIN_ORDER_USDC_ETH=9
# CANDLE_INTERVAL_ETH=1m
# CANDLE_LOOKBACK_ETH=200
# RSI_PERIOD_ETH=20
# MACD_FAST_ETH=12
# MACD_SLOW_ETH=30
# MACD_SIGNAL_ETH=9
# MAX_POSITION_PCT_ETH=0.03
#
# ETH hâlâ zayıfsa tek adım: MIN_EDGE_ETH=0.16 (veya MIN_ORDER_USDC_ETH=10) — ikisini birden sıkılaştırma.

# ── Execution ─────────────────────────────────────────────────────────────────
DRY_RUN=true             # set to false for live trading
CYCLE_SECS=60            # scan every 60 seconds

# ── Polymarket CLOB (optional) ────────────────────────────────────────────────
# CLOB_HOST=https://clob.polymarket.com   # Polymarket CLOB API endpoint

# Signature Type Configuration:
# SIGNATURE_TYPE=EOA           # Type 0: EOA (standard wallet) - DEFAULT
# SIGNATURE_TYPE=PROXY         # Type 1: Proxy contract
# SIGNATURE_TYPE=GNOSIS_SAFE   # Type 2: Gnosis Safe multisig
# SIGNATURE_TYPE=2             # Type 2: You can also use numeric value

# Funder Address (OPTIONAL for Proxy/GnosisSafe, must be EMPTY for EOA):
# FUNDER_ADDRESS=0x...         # The address that funds the trades
#
# SDK Auto-Derivation (NEW in v0.4.4+):
# - For Proxy/GnosisSafe: SDK automatically derives funder via CREATE2 if not set
# - For EOA: No funder needed (wallet itself is the funder)
# - Manual override: Set FUNDER_ADDRESS to override auto-derivation
#
# Example for Type 2 (GnosisSafe) with auto-derivation:
# SIGNATURE_TYPE=2
# POLYMARKET_PRIVATE_KEY=0xYourSignerPrivateKey
# (FUNDER_ADDRESS not needed - SDK will auto-derive)
#
# Example for Type 2 (GnosisSafe) with manual funder:
# SIGNATURE_TYPE=2
# FUNDER_ADDRESS=0xYourGnosisSafeAddress
# POLYMARKET_PRIVATE_KEY=0xYourSignerPrivateKey

# Note: Uses Polymarket SDK constants (POLYGON=137, Mainnet)

# ── Builder API (optional - for market makers only) ───────────────────────────
# If you have Builder API credentials from Polymarket, you can use them here.
# Builder API provides advanced endpoints for market makers with lower latency.
# To get Builder API credentials:
# 1. First authenticate with regular CLOB using your private key
# 2. Call the create_builder_api_key() endpoint
# 3. You'll receive: api_key, api_secret, and passphrase
# 4. Enter them below:

# BUILDER_API_KEY=your_builder_api_key
# BUILDER_API_SECRET=your_builder_api_secret
# BUILDER_API_PASSPHRASE=your_builder_passphrase

# Note: Builder API is NOT required for regular trading. Only use if you have credentials.

# ── Metrics & Data ────────────────────────────────────────────────────────────
# DATA_DIR=data
# JSONL: trades.jsonl, skip_reasons.jsonl, order_failures.jsonl
# Trade stats: cargo run --bin stats -- --data-dir data

# Higher timeframe filter (optional): last HTF close vs EMA on HTF candles must match spot signal direction.
# HTF_ENABLED=false
# HTF_INTERVAL=15m
# HTF_LOOKBACK=50
# HTF_EMA_PERIOD=20
# HTF_ENABLED_BTC=true

# Adaptive thresholds from recent resolved trades (optional; needs enough history in trades.jsonl)
# ADAPTIVE_THRESHOLDS=false
# ADAPTIVE_TRADE_WINDOW=50

# ── OpenTelemetry (optional) ───────────────────────────────────────────────────
# OTLP gRPC (Jaeger all-in-one: use port 4317 with COLLECTOR_OTLP_ENABLED=true)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=polymarket-llm-bot
# JSON logs (pairs well with log aggregators)
# LOG_JSON=false

# ── Prometheus (optional) ─────────────────────────────────────────────────────
# METRICS_ENABLED=true
# METRICS_BIND=127.0.0.1:9090
# Scrape: curl -s http://127.0.0.1:9090/metrics
